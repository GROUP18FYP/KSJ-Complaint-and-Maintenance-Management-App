<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/r83vjwcyvv55"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:paddingTop="40dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rxgcw8voqoh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_marginBottom="1dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/rcfsz14mn2ul"
                    android:layout_width="48dp"
                    android:layout_height="45dp"
                    android:scaleType="fitXY"
                    android:src="@android:drawable/star_big_on" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/racv7tbm53a"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complaint Form"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/rz7gm4c6qs0k"
                    android:layout_width="48dp"
                    android:layout_height="45dp"
                    android:scaleType="fitXY"
                    android:src="@android:drawable/star_big_on" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r8fl3y8eqyn8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="23dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/r830rq5o1yj"
                    android:textColor="#1E1E1E"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Name"
                    />
                <EditText
                    android:inputType="text"
                    android:hint="Alin Thuraya"
                    android:id="@+id/student_name"
                    android:textColor="#B3B3B3"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rufo8cuv9hg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="23dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/rw9k3gbk45nr"
                    android:textColor="#1E1E1E"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Room Number"
                    />
                <EditText
                    android:inputType="text"
                    android:hint="A2-77"
                    android:id="@+id/student_room_number"
                    android:textColor="#B3B3B3"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rom9znxlppp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="23dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/re2759saa3wf"
                    android:textColor="#1E1E1E"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Date preferred for service"
                    />
                <EditText
                    android:inputType="text"
                    android:hint="4 May 2026"
                    android:id="@+id/date_prefer_service"
                    android:textColor="#B3B3B3"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ryd9l901n9gg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="23dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/r6zqu6me2p93"
                    android:textColor="#1E1E1E"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Phone Number"
                    />
                <EditText
                    android:inputType="text"
                    android:hint="0123456678"
                    android:id="@+id/student_number"
                    android:textColor="#B3B3B3"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/r4ejvzj1nhou"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="9dp"
                android:layout_marginBottom="12dp"
                android:layout_marginHorizontal="23dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/rw4yqn2kpxrs"
                    android:textColor="#1E1E1E"
                    android:textSize="16sp"
                    android:layout_marginBottom="7dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Complain detail"
                    />
                <LinearLayout
                    android:id="@+id/rjjeegbm4307"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp"
                    android:layout_marginStart="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/rsg2q8s1yyv"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_marginEnd="14dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="􀓔"
                        />
                    <TextView
                        android:id="@+id/rwklw822vbs"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Leaking Pipe"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rc5j09a22zem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="3dp"
                    android:layout_marginStart="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/r60yc9vase2o"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_marginEnd="14dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="􀓔"
                        />
                    <TextView
                        android:id="@+id/rz1lx2al872"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Plumbing"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rkroyntzaty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/rg1uw98dxi7t"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_marginEnd="14dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="􀓔"
                        />
                    <TextView
                        android:id="@+id/rl9or94j3s5e"
                        android:textColor="#1A1A1A"
                        android:textSize="17sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Other: _______"
                        />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/rga29m2ueb5"
                android:textColor="#1E1E1E"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="25dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Photo reference"
                />
            <LinearLayout
                android:id="@+id/upload_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/s2c2c2csw1cr7b670e10"
                android:paddingVertical="5dp"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="13dp"
                android:layout_marginStart="38dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/rq3d7nbnw99"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="3dp"
                    app:srcCompat="@android:drawable/ic_menu_upload"
                    android:scaleType="fitXY"
                    />
                <TextView
                    android:id="@+id/r9g6y9f94toi"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Upload"
                    />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/submit_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:background="@drawable/s2c2c2csw1cr7b670e10"
                android:paddingVertical="18dp"
                android:layout_marginBottom="26dp"
                android:layout_marginHorizontal="20dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/rvk12ivlf86g"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submit"
                    android:textColor="#F5F5F5"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
