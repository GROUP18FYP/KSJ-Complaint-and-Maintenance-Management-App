<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/rktkwjuw0li"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#76002E"
        android:paddingTop="54dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/ry7xs3hm0oq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="#76002E"
                android:paddingVertical="6dp"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="18dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/r7wspa0r6mgd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/r68vqrxtzgzm"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        android:layout_marginBottom="6dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Welcome Back!"
                        />
                    <TextView
                        android:id="@+id/ros8jf5b0q0f"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Here’s what’s happening"
                        />
                </LinearLayout>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    />
                <ImageView
                    android:id="@+id/rksubsmsym5a"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/rgx1ykky8tca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="26dp"
                android:layout_marginHorizontal="20dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/history_click"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="15dp"
                    android:layout_marginEnd="21dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/r2kwhpdjsi1j"
                        android:layout_width="37dp"
                        android:layout_height="38dp"
                        android:layout_marginBottom="7dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                    <TextView
                        android:id="@+id/r0oea061ehspc"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="History"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/pending_click"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="14dp"
                    android:layout_marginEnd="21dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/r14zgplp45gw"
                        android:layout_width="39dp"
                        android:layout_height="39dp"
                        android:layout_marginBottom="8dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                    <TextView
                        android:id="@+id/rbymuzn1ihpv"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Pending"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/notification_click"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:paddingVertical="18dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/r550ea99axn8"
                        android:layout_width="34dp"
                        android:layout_height="35dp"
                        android:layout_marginBottom="5dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                    <TextView
                        android:id="@+id/rwe5v6cmceg"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Notification"
                        />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r4w2luygkh9t"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:orientation="vertical"
                android:paddingHorizontal="11dp"
                android:paddingTop="15dp">

                <LinearLayout
                    android:id="@+id/complaint_click"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="15dp">

                    <RelativeLayout
                        android:id="@+id/r8xwhmcn4abn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="11dp"
                        android:layout_marginBottom="29dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="1dp">

                            <ImageView
                                android:id="@+id/rk05c0h3mprf"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="20dp"
                                android:scaleType="fitXY"
                                app:srcCompat="@drawable/outline_add_notes_24" />

                            <LinearLayout
                                android:id="@+id/rmt59vqvcw1p"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingRight="28dp">

                                <TextView
                                    android:id="@+id/r7qh8i22xzpe"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="Complaint Form"
                                    android:textColor="#1E1E1E"
                                    android:textSize="19sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/rixlxjjii3if"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="This form is used to report maintenance issues such as electrical, plumbing, equipment, and facilities."
                                    android:textColor="#1E1E1E"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/feedback_click"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="206dp"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="16dp">

                    <RelativeLayout
                        android:id="@+id/rjx7iig989oo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="11dp"
                        android:layout_marginBottom="9dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/rurzz0bjpya"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="20dp"
                                android:scaleType="fitXY"
                                app:srcCompat="@drawable/outline_add_notes_24" />

                            <LinearLayout
                                android:id="@+id/r1sq6s6bhenc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/rsfednw6uif"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Feedback Form"
                                    android:textColor="#1E1E1E"
                                    android:textSize="19sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/royjgk6svqdr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="18dp"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/rsr82u0fmi7"
                            android:layout_width="265dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="25dp"
                            android:text="This form is used to report dissatisfaction or issues with services, staff, or experience"
                            android:textColor="#1E1E1E"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/ruzly3c7a17b"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="59dp"
                        android:background="@drawable/s767676sw1cr6be3e3e3"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="9dp">

                        <TextView
                            android:id="@+id/rm4ocfoiiizi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Click Here"
                            android:textColor="#1E1E1E"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>