<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/r6n6wla3sosx"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="#670E10"
        android:elevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/rand0z1g075"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp"
                >
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="51dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rjjs0zuic3el"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:elevation="4dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingTop="63dp">

                        <TextView
                            android:id="@+id/r00z2d5yeunrgi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="17dp"
                            android:text="Welcome Back!"
                            android:textColor="#000000"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/r2euahjaxz59"
                            android:layout_width="192dp"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="Sign in to continue to \nKSJ Complaint &amp; Mangement"
                            android:textColor="#000000"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:id="@+id/r282urzpcwaj"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_marginBottom="11dp"
                            android:background="@drawable/s76002esw1cr7bf3e6eb"
                            android:elevation="3dp"
                            android:orientation="vertical"
                            android:paddingVertical="24dp">

                            <LinearLayout
                                android:id="@+id/rngeemlfpi6"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="23dp"
                                android:layout_marginBottom="23dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/rtt5jk042obq"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="7dp"
                                    android:text="School Email Adress"
                                    android:textColor="#1E1E1E"
                                    android:textSize="15sp" />

                                <EditText
                                    android:id="@+id/rnao12ewd2ub"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                    android:hint="student@graduate.utm.my"
                                    android:inputType="text"
                                    android:minHeight="48dp"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="11dp"
                                    android:textColor="#B3B3B3"
                                    android:textSize="15sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/r3i64hggjm48"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="23dp"
                                android:layout_marginBottom="24dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/rkctj30vige"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="7dp"
                                    android:text="Password"
                                    android:textColor="#1E1E1E"
                                    android:textSize="15sp" />

                                <LinearLayout
                                    android:id="@+id/rmjts3ovbr6"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="11dp">

                                    <TextView
                                        android:id="@+id/rh0s5ktoll7m"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Enter your password"
                                        android:textColor="#B3B3B3"
                                        android:textSize="15sp" />

                                    <View
                                        android:layout_width="0dp"
                                        android:layout_height="0dp"
                                        android:layout_weight="1" />

                                    <ImageView
                                        android:id="@+id/rkn2yjvv843"
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:scaleType="fitXY"
                                        android:src="@android:drawable/star_big_on" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/register_btn"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="24dp"
                                android:layout_marginBottom="23dp"
                                android:background="@drawable/s2c2c2csw1cr7b670e10"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center_horizontal"
                                android:minHeight="48dp"
                                android:orientation="vertical"
                                android:paddingVertical="11dp">

                                <TextView
                                    android:id="@+id/textview53"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Log In"
                                    android:textColor="#F5F5F5"
                                    android:textSize="15sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/rg4htaoywphk"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="23dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/r7sfthslhr6d"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Forgot password?"
                                    android:textColor="#0088FF"
                                    android:textSize="15sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rqxrm64qr60k"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="224dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/rf3ol6cp2my9"
                    android:layout_marginTop="0dp"
                    android:layout_marginEnd="0dp"
                    android:layout_marginStart="0dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/r8ssp9fsyixb"
                        android:layout_width="104dp"
                        android:layout_height="101dp"
                        android:src="@android:drawable/star_big_on"
                        android:scaleType="fitXY"
                        />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

