<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:clipChildren="false"
        android:clipToPadding="false"
        android:id="@+id/rnlhbqed701k"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@drawable/cr3bffffff"
        android:paddingTop="43dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rzsblnjsycy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="6dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/ry2nn68ppi9"
                    android:layout_width="48dp"
                    android:layout_height="45dp"
                    android:layout_marginEnd="4dp"
                    android:src="@android:drawable/star_big_on"
                    android:scaleType="fitXY"
                    />
                <LinearLayout
                    android:id="@+id/rjmfl8rumsoc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rnn5euiyrr8"
                        android:textColor="#1D1B20"
                        android:textSize="22sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Your history"
                        />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:background="@drawable/cr100b78788026"
                android:padding="11dp"
                android:layout_marginBottom="20dp"
                android:layout_marginHorizontal="11dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/rk05c0h3mprf"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="20dp"
                    android:scaleType="fitXY"
                    app:srcCompat="@drawable/outline_add_notes_24" />
                    />
                <TextView
                    android:id="@+id/rl756ll6j1"
                    android:textColor="#727272"
                    android:textSize="17sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Search"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/r4ba4oh6xz4l"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="44dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/all_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/se6e6e6sw1cr6"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/r8bjuwvs2d1"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="All"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/pending_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/se6e6e6sw1cr6"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_marginEnd="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/r8bjuwvs2d1"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Pending"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/inprogress_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/se6e6e6sw1cr6"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/rpnoi3eyw1sq"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="In Progress"
                        />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/completed_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/se6e6e6sw1cr6"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/rpl4jg9g2nbh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/complaints_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp" />
            </ScrollView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
