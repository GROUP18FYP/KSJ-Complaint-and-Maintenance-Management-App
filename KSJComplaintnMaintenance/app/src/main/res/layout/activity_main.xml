<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@drawable/splash_screen">

    <LinearLayout
        android:layout_width="408dp"
        android:layout_height="621dp"
        android:background="#76002E"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="2dp"
        tools:layout_editor_absoluteY="109dp">

        <LinearLayout
            android:id="@+id/rxnbs0fsa6a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/s7d5260sw1cr10bf3e6eb"
            android:paddingVertical="8dp"

            android:layout_marginBottom="48dp"
            android:layout_marginHorizontal="14dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rd7m5y3gk43v"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginBottom="2dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/raltzap9a0cv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="13dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rwx71oyufwzh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/rb7422f9zgte"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Complaint"
                            android:textColor="#1E1E1E"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rhznyg3438sq"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="46dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/r6sszs4vgfcf"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="12dp"
                            android:orientation="vertical"></LinearLayout>

                        <LinearLayout
                            android:id="@+id/rz9lk0g9mo08"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingBottom="2dp">

                            <TextView
                                android:id="@+id/complaint_type"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/priority_colour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/se6e6e6sw1cr6"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingBottom="3dp">

                    <TextView
                        android:id="@+id/priority_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#090909"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rou4i84936sc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="42dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/ry2nn68ppi9"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="1dp"
                    app:srcCompat="@drawable/outline_calendar_month_24"
                    android:scaleType="fitXY"
                    />

                <TextView
                    android:id="@+id/date_submit"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r2u9lxin0efm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/progress_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:srcCompat="@android:drawable/ic_menu_upload" />

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ksj_logo" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
