<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scrollViewLogin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#670E10"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="50dp">

            <LinearLayout
                android:id="@+id/rf3ol6cp2my9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="51dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:elevation="4dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingTop="63dp">

                        <!-- SECTION 1: REGISTRATION FIELDS -->
                        <LinearLayout
                            android:id="@+id/registration_layout"
                            android:layout_width="match_parent"
                            android:layout_height="629dp"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginBottom="17dp"
                                android:text="Registration"
                                android:textColor="#000000"
                                android:textSize="24sp" />

                            <TextView
                                android:id="@+id/textview2"
                                android:layout_width="192dp"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:text="Sign in to continue to \nKSJ Complaint &amp; Management"
                                android:textColor="#000000"
                                android:textSize="14sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="10dp"
                                android:background="@drawable/s76002esw1cr7bf3e6eb"
                                android:elevation="3dp"
                                android:orientation="vertical"
                                android:paddingVertical="24dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="23dp"
                                    android:layout_marginBottom="24dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="7dp"
                                        android:text="Full Name"
                                        android:textColor="#1E1E1E"
                                        android:textSize="15sp" />

                                    <EditText
                                        android:id="@+id/user_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                        android:hint="Full Name"
                                        android:minHeight="48dp"
                                        android:padding="12dp"
                                        android:paddingHorizontal="14dp"
                                        android:paddingVertical="11dp"
                                        android:textColor="#000000" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="23dp"
                                    android:layout_marginBottom="24dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="7dp"
                                        android:text="School Email Address"
                                        android:textColor="#1E1E1E"
                                        android:textSize="15sp" />

                                    <EditText
                                        android:id="@+id/user_email"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                        android:hint="School Email"
                                        android:inputType="textEmailAddress"
                                        android:minHeight="48dp"
                                        android:padding="12dp"
                                        android:textColor="#000000" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="23dp"
                                    android:layout_marginBottom="24dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="7dp"
                                        android:text="Password"
                                        android:textColor="#1E1E1E"
                                        android:textSize="15sp" />

                                    <EditText
                                        android:id="@+id/passwords"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                        android:hint="Password"
                                        android:inputType="textPassword"
                                        android:minHeight="48dp"
                                        android:padding="12dp"
                                        android:textColor="#000000" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="7dp"
                                        android:layout_marginBottom="7dp"
                                        android:text="*Min. 8 character, 1 lowercase, 1 special character Example: !@#$%^*"
                                        android:textColor="#4CAF50"
                                        android:textSize="15sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/register_btn"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="24dp"
                                    android:background="@drawable/s2c2c2csw1cr7b670e10"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:gravity="center"
                                    android:minHeight="48dp"
                                    android:padding="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Register"
                                        android:textColor="#FFFFFF" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- SECTION 2: VERIFICATION FIELDS (Hidden by default) -->
                        <LinearLayout
                            android:id="@+id/verification_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:padding="20dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verify Email"
                                android:textColor="#000000"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enter the 6-digit code sent to you"
                                android:layout_marginBottom="20dp"/>

                            <EditText
                                android:id="@+id/otp_input"
                                android:layout_width="200dp"
                                android:layout_height="50dp"
                                android:background="@drawable/sd9d9d9sw1cr7bffffff"
                                android:gravity="center"
                                android:hint="000000"
                                android:inputType="number"
                                android:maxLength="6"
                                android:textSize="20sp"
                                android:textColor="#000000" />

                            <Button
                                android:id="@+id/verify_final_btn"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:text="Verify &amp; Start"
                                android:backgroundTint="#670E10" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- LOGO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal">
                    <androidx.cardview.widget.CardView
                        android:layout_width="104dp"
                        android:layout_height="101dp"
                        app:cardCornerRadius="20dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:srcCompat="@drawable/ksj_logo"
                            android:scaleType="fitCenter" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>


