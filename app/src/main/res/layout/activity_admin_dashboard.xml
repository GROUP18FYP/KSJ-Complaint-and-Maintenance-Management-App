<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminDashboard">

    <FrameLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#76002E">

        <ScrollView
            android:id="@+id/rktkwjuw0li"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#76002E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#76002E"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/ry7xs3hm0oq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="#76002E"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="25dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:id="@+id/r7wspa0r6mgd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@+id/rksubsmsym5a"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/r68vqrxtzgzm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome Back!"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/ros8jf5b0q0f"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Here’s what’s happening"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/rksubsmsym5a"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_action_menu" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#76002E"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="20dp"
                    android:weightSum="2">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="#76002E"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tv_total_complaints_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#000000"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_feedback_stat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg Rating"
                                android:textColor="#76002E"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tv_avg_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#000000"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/r4w2luygkh9tw"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8E8EB"
                    android:elevation="4dp"
                    android:minHeight="600dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="11dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Actions"
                        android:textColor="#555555"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/user_managementbtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4abn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/rk05c0h3mprf"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@mipmap/ic_launcher_user_management" />

                                <LinearLayout
                                    android:id="@+id/rmt59vqvcw1p"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/r7qh8i22xzpe"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="User Management"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/rixlxjjii3if"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Create, Read, Update, Delete the user to database"
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/admin_complaint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4abng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/rk05c0h3mprfw"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@drawable/outline_add_notes_24" />

                                <LinearLayout
                                    android:id="@+id/rmt59vqvcw1pt"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/r7qh8i22xzpes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="Complaint List"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/rixlxjjii3ifk"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Read, Update, Delete the complaint that have been made"
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/admin_create_user"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4sabng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/rk05c0gh3mprfw"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@drawable/ic_action_add_user" />

                                <LinearLayout
                                    android:id="@+id/rmt59vqvcw31pt"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/r7qh8i22fxzpes"
                                        android:layout_width="159dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="Create New User"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/rixlxijjii3ifk"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Create new user (student,staff,admin) into database"
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/admin_monthly_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4sabuwng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="1dp">

                            <ImageView
                                android:id="@+id/rk05c0gh3mkuprfw"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="20dp"
                                android:scaleType="fitXY"
                                app:srcCompat="@mipmap/ic_launcher_summary" />

                            <LinearLayout
                                android:id="@+id/rmt59vqvcw3156pt"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingRight="28dp">

                                <TextView
                                    android:id="@+id/r7qh8i22fxzpfes"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="12dp"
                                    android:text="Monthly Complaint Summary"
                                    android:textColor="#1E1E1E"
                                    android:textSize="19sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/rixlxijjiit3ifk"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Get the monthly trends and statistic and view previous month trends.\nExport/Download the pdf file."
                                    android:textColor="#1E1E1E"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>

                </LinearLayout>

                    <LinearLayout
                        android:id="@+id/admin_feedback_board"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/feedback_board_rl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/feedback_icon"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@android:drawable/ic_menu_view" />

                                <LinearLayout
                                    android:id="@+id/feedback_text_container"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/feedback_title"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="Feedback Board"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/feedback_desc"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="View all feedback given by students regarding staff performance."
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/admin_menu" />

</androidx.drawerlayout.widget.DrawerLayout>