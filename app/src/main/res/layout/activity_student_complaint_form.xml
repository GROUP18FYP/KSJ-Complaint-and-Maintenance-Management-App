<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StudentComplaintForm">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/ScrollView34"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingTop="43dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <!-- Standardized Header -->
                <LinearLayout
                    android:id="@+id/LinearLayout11"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/returnStudentDashboard"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_action_menu2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/complaints_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Complaint Form"
                            android:textColor="#1D1B20"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/rz7gm4c6qs0k"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerInside"
                        android:visibility="invisible" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="30dp" />

                <!-- Name Field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Name"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/student_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:hint="Your full name"
                        android:inputType="textPersonName"
                        android:minHeight="48dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Room Number Field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Room Number"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/student_room_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:hint="Eg: A1-01"
                        android:inputType="text"
                        android:minHeight="48dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Date Field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Date preferred for service"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/date_prefer_service"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:hint="Eg: 2026-01-15"
                        android:inputType="text"
                        android:minHeight="48dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Phone Number Field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Phone Number"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/student_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:hint="Eg: 0123456789"
                        android:inputType="phone"
                        android:minHeight="48dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Complaint Detail -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:text="Complain Detail"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <CheckBox
                        android:id="@+id/leaking_pipe_cbx"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="Leaking Pipe"
                        android:textColor="#1E1E1E" />

                    <CheckBox
                        android:id="@+id/plumbing_cbx"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="Plumbing"
                        android:textColor="#1E1E1E" />

                    <CheckBox
                        android:id="@+id/other_cbx"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="Other"
                        android:textColor="#1E1E1E" />

                    <EditText
                        android:id="@+id/other_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:hint="Please specify if other"
                        android:inputType="text"
                        android:minHeight="48dp"
                        android:padding="12dp"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Description Field -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="7dp"
                        android:text="Description"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/complaint_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:gravity="top"
                        android:hint="Provide more details"
                        android:inputType="textMultiLine"
                        android:minHeight="100dp"
                        android:padding="12dp"
                        android:textColor="#000000"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Photo Upload Section -->
                <LinearLayout
                    android:id="@+id/r4ejvzjl1nhou"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Photo Reference"
                        android:textColor="#1E1E1E"
                        android:textSize="16sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/upload_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/s2c2c2csw1cr7b670e10"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:orientation="horizontal"
                            android:paddingHorizontal="15dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="8dp"
                                app:srcCompat="@android:drawable/ic_menu_upload"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/photo_attached"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="No file selected"
                            android:textColor="#727272"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Photo Preview (Hidden initially) -->
                <ImageView
                    android:id="@+id/photo_preview"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginBottom="12dp"
                    android:scaleType="centerInside"
                    android:visibility="gone" />

                <!-- Submit Button -->
                <LinearLayout
                    android:id="@+id/submit_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="26dp"
                    android:background="@drawable/s2c2c2csw1cr7b670e10"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="18dp">

                    <TextView
                        android:id="@+id/submit_btn_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUBMIT COMPLAINT"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/student_menu" />

</androidx.drawerlayout.widget.DrawerLayout>