<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBD7E3"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/rf3ol6cp2my9"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        android:gravity="center_horizontal"
        android:orientation="vertical" />

    <LinearLayout
        android:id="@+id/rf3ol6cp2my9b"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="104dp"
            android:layout_height="101dp"
            app:cardCornerRadius="20dp">

            <ImageView
                android:layout_width="104dp"
                android:layout_height="101dp"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ksj_logo" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rf3ol6cp2my9t"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_horizontal"
        android:orientation="vertical" />

    <LinearLayout
        android:id="@+id/linearlayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="11dp"
        android:background="@drawable/s76002esw1cr7bf3e6eb"
        android:elevation="3dp"
        android:orientation="vertical"
        android:paddingVertical="24dp">

        <!-- EMAIL INPUT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="23dp"
            android:layout_marginBottom="23dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="OTP"
                android:layout_gravity="center"
                android:textColor="#1E1E1E"
                android:textSize="30sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp"
                android:layout_marginBottom="23dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="7dp"
                    android:text="Enter Code"
                    android:textColor="#1E1E1E"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/reset_otp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/sd9d9d9sw1cr7bffffff"
                    android:hint="Enter 6-digit code"
                    android:inputType="number"
                    android:maxLength="6"
                    android:minHeight="48dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="11dp"
                    android:textColor="#000000"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- PASSWORD INPUT -->

            <LinearLayout
                android:id="@+id/continue_resetBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/s2c2c2csw1cr7b670e10"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="48dp"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/resend_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="Didn't receive the email? Click here"
            android:textColor="#32A0F4"
            android:textStyle="bold"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/go_to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:text="Back to Log In"
            android:textColor="#000000"
            android:textStyle="bold"
            tools:ignore="TouchTargetSizeCheck" />

    </LinearLayout>
</LinearLayout>