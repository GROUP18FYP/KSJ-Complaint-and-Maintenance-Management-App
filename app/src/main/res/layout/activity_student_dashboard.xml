<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StudentDashboard">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#76002E"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/rktkwjuw0li"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#76002E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#76002E"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/ry7xs3hm0oq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="#76002E"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="25dp"
                    android:paddingBottom="6dp">

                    <LinearLayout
                        android:id="@+id/r7wspa0r6mgd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@+id/logout_btn"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/r68vqrxtzgzm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome Back!"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp" />

                        <TextView
                            android:id="@+id/ros8jf5b0q0f"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Here’s what’s happening"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/logout_btn"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_action_menu"
                        tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/rgx1ykky8tca"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="26dp"
                    android:background="#76002E"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/history_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <ImageView
                            android:id="@+id/r2kwhpdjsi1j"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginBottom="7dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_action_file"
                            app:tint="#D32F2F" />

                        <TextView
                            android:id="@+id/r0oea061ehspc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="History"
                            android:textColor="#000000"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/pending_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <ImageView
                            android:id="@+id/r14zgplp45gw"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginBottom="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_action_progress"
                            app:tint="#388E3C" />

                        <TextView
                            android:id="@+id/rbymuzn1ihpv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In Progress"
                            android:textColor="#000000"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/notification_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/r550ea99axn8"
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:layout_marginBottom="5dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_action_bell"
                                app:tint="#1976D2" />

                            <TextView
                                android:id="@+id/notification_badge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignTop="@id/r550ea99axn8"
                                android:layout_alignEnd="@id/r550ea99axn8"
                                android:background="@android:color/holo_red_dark"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="#FFFFFF"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/rwe5v6cmceg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification"
                            android:textColor="#000000"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/r4w2luygkh9t"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8E8EB"
                    android:elevation="4dp"
                    android:minHeight="600dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="11dp"
                    android:paddingTop="15dp"
                    android:paddingBottom="40dp">

                    <LinearLayout
                        android:id="@+id/complaint_click"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4abn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/rk05c0h3mprf"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@drawable/outline_add_notes_24" />

                                <LinearLayout
                                    android:id="@+id/rmt59vqvcw1p"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/r7qh8i22xzpe"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="Complaint Form"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/rixlxjjii3if"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="This form is used to report maintenance issues such as electrical, plumbing, equipment, and facilities."
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/feedback_click"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/sd9d9d9sw1cr7bffffff"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <RelativeLayout
                            android:id="@+id/r8xwhmcn4abng"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="11dp"
                            android:layout_marginBottom="29dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingVertical="1dp">

                                <ImageView
                                    android:id="@+id/rk05c0h3mprfw"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="20dp"
                                    android:scaleType="fitXY"
                                    app:srcCompat="@drawable/outline_add_notes_24" />

                                <LinearLayout
                                    android:id="@+id/rmt59vqvcw1pt"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:paddingRight="28dp">

                                    <TextView
                                        android:id="@+id/r7qh8i22xzpes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginBottom="12dp"
                                        android:text="Feedback Form"
                                        android:textColor="#1E1E1E"
                                        android:textSize="19sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/rixlxjjii3ifk"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="This form is used to report dissatisfaction or issues with services, staff, or experience"
                                        android:textColor="#1E1E1E"
                                        android:textSize="12sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/student_menu" />

</androidx.drawerlayout.widget.DrawerLayout>